---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import BlogCard from "../../components/BlogCard.astro";

const modules = import.meta.glob("../../content/blog/*.md", { eager: true });

const posts = Object.entries(modules)
  .map(([path, post]) => {
    const slug = path.split("/").pop().replace(".md", "");
    return {
      slug,
      ...post.frontmatter,
    };
  })
  .sort((a, b) => new Date(b.date) - new Date(a.date));
---

<BaseLayout
  title="The Diva Blog | The Diva Shopper"
  description="All shopping guides, beauty picks, fashion finds, and girly product blogs from The Diva Shopper."
>
  <Header />

  <main>
    <section class="page-hero">
      <div class="container">
        <p class="eyebrow">Blog</p>
        <h1>The Diva Blog</h1>
        <p>All shopping guides, product roundups, and diva-approved finds.</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="search-wrap">
          <input
            type="search"
            placeholder="Search all blogs..."
            data-blog-search
            data-target="#all-blog-grid"
          />
        </div>

        <div id="all-blog-grid" class="blog-grid">
          {posts.map((post) => <BlogCard post={post} />)}
          <p class="empty-message" data-empty hidden>No matching blogs found.</p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
