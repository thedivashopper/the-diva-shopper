---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BlogCard from "../components/BlogCard.astro";

const modules = import.meta.glob("../content/blog/*.md", { eager: true });

const posts = Object.entries(modules)
  .map(([path, post]) => {
    const slug = path.split("/").pop().replace(".md", "");
    return {
      slug,
      ...post.frontmatter,
    };
  })
  .sort((a, b) => new Date(b.date) - new Date(a.date));

const latestPosts = posts.slice(0, 6);
---

<BaseLayout
  title="The Diva Shopper | Cute Finds, Beauty Picks & Fashion Favorites"
  description="Simple shopping guides and diva-approved finds for beauty, fashion, Amazon finds, and other girly products."
>
  <Header />

  <main>
    <section class="hero">
      <div class="container hero-inner">
        <p class="eyebrow">Diva-approved finds</p>
        <h1>Cute Finds, Beauty Picks & Fashion Favorites</h1>
        <p class="hero-text">
          Simple shopping guides and diva-approved finds for beauty, fashion,
          Amazon finds, and other girly products.
        </p>

        <div class="hero-actions">
          <a class="btn primary" href="/blog">Read the Blog</a>
          <a class="btn secondary" href="#latest">Latest Posts</a>
        </div>
      </div>
    </section>

    <section id="latest" class="section">
      <div class="container">
        <div class="section-heading">
          <p class="eyebrow">Latest</p>
          <h2>Latest Blogs</h2>
          <p>Search or browse the newest guides from The Diva Shopper.</p>
        </div>

        <div class="search-wrap">
          <input
            type="search"
            placeholder="Search blogs..."
            data-blog-search
            data-target="#home-blog-grid"
          />
        </div>

        <div id="home-blog-grid" class="blog-grid">
          {latestPosts.map((post) => <BlogCard post={post} />)}
          <p class="empty-message" data-empty hidden>No matching blogs found.</p>
        </div>

        <div class="center">
          <a class="btn primary" href="/blog">View All Blogs</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
